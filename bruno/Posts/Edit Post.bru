meta {
  name: Edit Post
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/posts/:id
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

params:path {
  id: REPLACE_WITH_POST_ID
}

body:json {
  {
    "title": "Updated Title",
    "content": "Updated content goes here."
  }
}
