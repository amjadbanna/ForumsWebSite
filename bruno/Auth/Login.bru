meta {
  name: Login User
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "username": "amjad",
    "password": "password123"
  }
}

script:post-response {
  // Save the returned token so all protected requests can use {{token}}
  if (res.body.token) {
    bru.setVar("token", res.body.token);
  }
}
